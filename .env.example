# Variáveis mínimas para execução local e CI
# Copie para .env.local (desenvolvimento) ou configure no provedor de deploy.

# Banco de dados
# Obrigatória em staging/producao e para autenticacao admin.
# Em desenvolvimento local, quando ausente, leads e page content usam fallback em arquivo.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
# Obrigatoria em producao para habilitar autenticacao admin.
NEXTAUTH_SECRET="change-me-with-a-long-random-secret"

# Opcional: bloqueia /admin, /login e /api no deploy de verificação visual
FRONTEND_ONLY="false"
