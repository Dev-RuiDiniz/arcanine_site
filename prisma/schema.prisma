/*
Arquivo: prisma/schema.prisma
Objetivo: Schema do banco de dados para o Prisma ORM.
Guia rapido: consulte imports no topo, depois tipos/constantes, e por fim a exportacao principal.
*/

// ARCANINE Tecnologia - Schema do Banco de Dados
// Plataforma institucional e operacional

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// AUTENTICAÇÃO (Admin)
// ============================================

model User {
  id                   String        @id @default(cuid())
  name                 String?
  email                String        @unique
  emailVerified        DateTime?
  image                String?
  password             String?
  role                 Role          @default(ADMIN)
  accounts             Account[]
  sessions             Session[]
  updatedPageContents  PageContent[] @relation("PageContentUpdatedBy")
  publishedPageContents PageContent[] @relation("PageContentPublishedBy")
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  ADMIN
  EDITOR
}

// ============================================
// PROJETOS
// ============================================

model Project {
  id          String         @id @default(cuid())
  slug        String         @unique
  title       String
  subtitle    String?
  location    String
  category    ProjectCategory
  status      ProjectStatus  @default(PUBLISHED)
  description String?        @db.Text
  coverImage  String
  year        String?
  client      String?
  area        String?
  credits     String?        @db.Text
  featured    Boolean        @default(false)
  order       Int            @default(0)
  images      ProjectImage[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model ProjectImage {
  id        String   @id @default(cuid())
  url       String
  alt       String?
  width     Int?
  height    Int?
  order     Int      @default(0)
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

enum ProjectCategory {
  SOFTWARE_PLATFORM
  AUTOMATION
  COMMERCE
  DATA_AI
}

enum ProjectStatus {
  DRAFT
  PUBLISHED
  COMING_SOON
  WORK_IN_PROGRESS
}

// ============================================
// SERVIÇOS
// ============================================

model Service {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  subtitle    String?
  description String?  @db.Text
  coverImage  String?
  icon        String?
  features    String[] @default([])
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================
// CONTATOS / LEADS
// ============================================

model Contact {
  id        String        @id @default(cuid())
  name      String
  email     String
  company   String?
  phone     String?
  subject   String?
  intent    String?
  projectType String?
  budgetRange String?
  message   String        @db.Text
  status    ContactStatus @default(NEW)
  source    String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

enum ContactStatus {
  NEW
  READ
  REPLIED
  ARCHIVED
}

// ============================================
// CONFIGURAÇÕES DO SITE
// ============================================

model SiteSettings {
  id              String   @id @default(cuid())
  siteName        String   @default("ARCANINE Tecnologia")
  tagline         String?
  email           String?
  phone           String?
  address         String?
  linkedin        String?
  aboutText       String?  @db.Text
  aboutImage      String?
  heroVideoUrl    String?
  heroImageUrl    String?
  heroTitle       String?
  heroSubtitle    String?
  metaTitle       String?
  metaDescription String?  @db.Text
  updatedAt       DateTime @updatedAt
}

model PageContent {
  id            String   @id @default(cuid())
  pageId        String   @unique
  draft         Json
  published     Json
  updatedAt     DateTime @updatedAt
  publishedAt   DateTime?
  updatedById   String?
  publishedById String?
  updatedBy     User?    @relation("PageContentUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  publishedBy   User?    @relation("PageContentPublishedBy", fields: [publishedById], references: [id], onDelete: SetNull)
}
